    {
      "id": "cli-service-text",
      "type": "text",
      "x": 75,
      "y": 558,
      "width": 270,
      "height": 208,
      "text": "GitHubCopilotCliService\n═══════════════════════\nCopilotClient  ←  new CopilotClient(opts)\nCopilotSession ←  client.createSession()\n──────────────────────\nstart() / stop()\ncreateSession(id?) / resumeSession(id)\nsendMessage(prompt, timeout, images)\nsendMessageStreaming(prompt, onDelta, ...)\nabort() / compactSession()\nlistModels() → model catalog\n──────────────────────\nTemplate Method Hooks:\n• buildTools()  → BasicToolFactory\n• buildSystemPrompt()\n• buildSummarizer()",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#c92a2a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "groupIds": [],
      "roundness": null,
      "seed": 3003,
      "version": 1,
      "versionNonce": 3003,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1709500000000,
      "link": null,
      "locked": false,
      "containerId": "cli-service",
      "originalText": "GitHubCopilotCliService\n═══════════════════════\nCopilotClient  ←  new CopilotClient(opts)\nCopilotSession ←  client.createSession()\n──────────────────────\nstart() / stop()\ncreateSession(id?) / resumeSession(id)\nsendMessage(prompt, timeout, images)\nsendMessageStreaming(prompt, onDelta, ...)\nabort() / compactSession()\nlistModels() → model catalog\n──────────────────────\nTemplate Method Hooks:\n• buildTools()  → BasicToolFactory\n• buildSystemPrompt()\n• buildSummarizer()",
      "autoResize": true,
      "lineHeight": 1.25
    },
